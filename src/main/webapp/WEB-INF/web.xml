<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd" version="6.0">
<display-name>Entre Aspas</display-name>
<description>Clube de leitura Entre Aspas</description>

<welcome-file-list>
<welcome-file>login.jsp</welcome-file>
</welcome-file-list>

<!-- ── Autenticação / Cadastro ─────────────────────────── -->
<servlet>
<servlet-name>LoginServlet</servlet-name>
<servlet-class>servlets.LoginServlet</servlet-class>
</servlet>
<servlet-mapping>
<servlet-name>LoginServlet</servlet-name>
<url-pattern>/login</url-pattern>
</servlet-mapping>

<servlet>
<servlet-name>CadastroServlet</servlet-name>
<servlet-class>servlets.CadastroServlet</servlet-class>
</servlet>
<servlet-mapping>
<servlet-name>CadastroServlet</servlet-name>
<url-pattern>/cadastro</url-pattern>
</servlet-mapping>

<servlet>
<servlet-name>LogoutServlet</servlet-name>
<servlet-class>servlets.LogoutServlet</servlet-class>
</servlet>
<servlet-mapping>
<servlet-name>LogoutServlet</servlet-name>
<url-pattern>/logout</url-pattern>
</servlet-mapping>

<!-- Mapeia a URL /login/erro diretamente para a JSP, sem precisar de um Servlet .java -->
<servlet>
<servlet-name>LoginErroJsp</servlet-name>
<jsp-file>/login-erro.jsp</jsp-file>
</servlet>
<servlet-mapping>
<servlet-name>LoginErroJsp</servlet-name>
<url-pattern>/login/erro</url-pattern>
</servlet-mapping>

<servlet>
<servlet-name>HomeServlet</servlet-name>
<servlet-class>servlets.HomeServlet</servlet-class>
</servlet>
<servlet-mapping>
<servlet-name>HomeServlet</servlet-name>
<url-pattern>/home</url-pattern>
</servlet-mapping>

<!-- ── CRUD principal ──────────────────────────────────── -->
<servlet>
<servlet-name>UsuarioServlet</servlet-name>
<servlet-class>servlets.UsuarioServlet</servlet-class>
</servlet>
<servlet-mapping>
<servlet-name>UsuarioServlet</servlet-name>
<url-pattern>/usuario</url-pattern>
</servlet-mapping>

<servlet>
<servlet-name>LivroServlet</servlet-name>
<servlet-class>servlets.LivroServlet</servlet-class>
</servlet>
<servlet-mapping>
<servlet-name>LivroServlet</servlet-name>
<url-pattern>/livro</url-pattern>
</servlet-mapping>

<servlet>
<servlet-name>DesafioServlet</servlet-name>
<servlet-class>servlets.DesafioServlet</servlet-class>
</servlet>
<servlet-mapping>
<servlet-name>DesafioServlet</servlet-name>
<url-pattern>/desafio</url-pattern>
</servlet-mapping>

<servlet>
<servlet-name>AvaliacaoServlet</servlet-name>
<servlet-class>servlets.AvaliacaoServlet</servlet-class>
</servlet>
<servlet-mapping>
<servlet-name>AvaliacaoServlet</servlet-name>
<url-pattern>/avaliacao</url-pattern>
</servlet-mapping>

<!-- ── Impressão (upload/download em contexto) ─────────── -->
<servlet>
<servlet-name>CarteirinhaServlet</servlet-name>
<servlet-class>servlets.CarteirinhaServlet</servlet-class>
</servlet>
<servlet-mapping>
<servlet-name>CarteirinhaServlet</servlet-name>
<url-pattern>/carteirinha</url-pattern>
</servlet-mapping>

<servlet>
<servlet-name>FichaLeituraServlet</servlet-name>
<servlet-class>servlets.FichaLeituraServlet</servlet-class>
</servlet>
<servlet-mapping>
<servlet-name>FichaLeituraServlet</servlet-name>
<url-pattern>/ficha-leitura</url-pattern>
</servlet-mapping>

</web-app>
